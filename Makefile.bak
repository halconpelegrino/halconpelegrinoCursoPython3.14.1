cat > Makefile <<'EOF'
VENV = curso
PY = $(VENV)/bin/python
PIP = $(VENV)/bin/pip
BLACK = $(VENV)/bin/black
RUFF = $(VENV)/bin/ruff
PYTEST = $(VENV)/bin/pytest

.PHONY: venv install format lint test clean

venv:
    python3 -m venv $(VENV)

install: venv
    $(PIP) install --upgrade pip setuptools wheel
    $(PIP) install -r requirements.txt

format:
    $(BLACK) .

lint:
    $(RUFF) check .

test:
    $(PYTEST)

clean:
    find . -type d -name "__pycache__" -exec rm -rf {} +
    rm -f *.pyc
EOF
